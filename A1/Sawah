Framework.GetRemote = function(self, remoteName)
    if self.Cache.Remotes[remoteName] then return self.Cache.Remotes[remoteName] end
    local remote = Services.ReplicatedStorage:FindFirstChild(remoteName, true)
    if remote then self.Cache.Remotes[remoteName] = remote end
    return remote
end

Framework.AddConnection = function(self, conn, isStreamer)
    if typeof(conn) == "RBXScriptConnection" then 
        if isStreamer then table.insert(self.StreamerConns, conn) else table.insert(self.Connections, conn) end
    end
end

Framework.CancelTask = function(self, taskName)
    if self.ActiveTasks[taskName] then 
        task.cancel(self.ActiveTasks[taskName])
        self.ActiveTasks[taskName] = nil 
    end
end

local function FormatRp(amount)
    local formatted = tostring(tonumber(amount) or 0)
    local k
    while true do
        formatted, k = string.gsub(formatted, "^(-?%d+)(%d%d%d)", '%1.%2')
        if k == 0 then break end
    end
    return "Rp " .. formatted
end

