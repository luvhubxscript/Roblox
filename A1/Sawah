                end
            end
        end
        if Win then Win:Notify({Title = "Gagal", Text = "Lahan Buah belum diklaim atau tidak ditemukan!", Duration = 3}) end
    end,
    ToKandang = function(tipeKandang, Win)
        local lpName = Framework.Cache.LocalPlayer.Name
        local lpId = Framework.Cache.LocalPlayer.UserId
        local targetKeyword = "Coop"
        local animalKeyword = "Ayam"
        
        if tipeKandang == "Sapi" then
            targetKeyword = "Barn"
            animalKeyword = "Sapi"
        end
        
        for _, v in pairs(Services.Workspace:GetChildren()) do
            if v:IsA("Model") and string.find(v.Name, targetKeyword) and string.find(v.Name, lpName) then
                local root = v.PrimaryPart or v:FindFirstChildWhichIsA("BasePart", true)
                if root and Framework.Cache.HumanoidRootPart then
                    Framework.Cache.HumanoidRootPart.CFrame = root.CFrame + Vector3.new(0, 5, 0)
                    if Win then Win:Notify({Title = "Teleport", Text = "Berhasil TP ke Kandang " .. tipeKandang, Duration = 2}) end
                    return
                end
            end
        end

        for _, animal in pairs(Services.Workspace:GetDescendants()) do
            if animal:IsA("Model") and string.find(animal.Name, animalKeyword) then
                if animal:GetAttribute("OwnerId") == lpId then
                    local root = animal:FindFirstChild("HumanoidRootPart") or animal.PrimaryPart or animal:FindFirstChildWhichIsA("BasePart")
                    if root and Framework.Cache.HumanoidRootPart then
                        Framework.Cache.HumanoidRootPart.CFrame = root.CFrame + Vector3.new(0, 5, 0)
                        if Win then Win:Notify({Title = "Teleport", Text = "Berhasil TP ke Kandang " .. tipeKandang, Duration = 2}) end
                        return
                    end
                end
            end
        end
        if Win then Win:Notify({Title = "Gagal", Text = "Kandang " .. tipeKandang .. " tidak ditemukan!", Duration = 3}) end
    end,
    ClaimKandang = function(tipeKandang, Win)
        local fallbackKeyword = "coop"
        if tipeKandang == "Sapi" then 
            fallbackKeyword = "barn" 
        end
        
        local targetPrompt = nil
        
        for _, prompt in pairs(Services.Workspace:GetDescendants()) do
            if prompt:IsA("ProximityPrompt") and prompt.Enabled then
                local aTxt = string.lower(prompt.ActionText)
                local pName = string.lower(prompt.Parent.Name)
                
                if string.find(aTxt, "claim") or string.find(aTxt, "klaim") or string.find(aTxt, "beli") or string.find(aTxt, "buka") then
                    if string.find(pName, fallbackKeyword) then
                        targetPrompt = prompt
                        break
                    end
                end
            end
        end
        
        if targetPrompt and Framework.Cache.HumanoidRootPart then
            local origin = Framework.Cache.HumanoidRootPart.CFrame
            Framework.Cache.HumanoidRootPart.CFrame = targetPrompt.Parent.CFrame + Vector3.new(0, 3, 0)
            task.wait(0.5)
            targetPrompt.HoldDuration = 0
            fireproximityprompt(targetPrompt, 1)
            task.wait(1)
            Framework.Cache.HumanoidRootPart.CFrame = origin
            if Win then Win:Notify({Title = "Auto Claim", Text = "Berhasil klaim Kandang " .. tipeKandang, Duration = 3}) end
            return
        end
        if Win then Win:Notify({Title = "Gagal", Text = "Tidak ada Kandang " .. tipeKandang .. " kosong!", Duration = 3}) end
    end
}

Modules.Farming = {
    GetSeedCount = function(seedName)
        local count = 0
        local bp = Framework.Cache.LocalPlayer:FindFirstChild("Backpack")
        local char = Framework.Cache.Character
        local function countIn(folder)
            if not folder then return end
            for _, item in pairs(folder:GetChildren()) do
                if item:IsA("Tool") and string.find(string.lower(item.Name), string.lower(seedName)) then
                    local amount = string.match(item.Name, "x(%d+)")
                    if amount then count = count + tonumber(amount) else count = count + 1 end
                end
            end
        end
        countIn(bp)
        countIn(char)
        return count
    end,
    ForceEquipTool = function(targetName)
        local char = Framework.Cache.Character
        local hum = Framework.Cache.Humanoid
        local bp = Framework.Cache.LocalPlayer:FindFirstChild("Backpack")
        if not char or not hum then return false end
        
        local heldTool = char:FindFirstChildOfClass("Tool")
        if heldTool and string.find(string.lower(heldTool.Name), string.lower(targetName)) then 
            return true 
        end
        
        hum:UnequipTools()
        task.wait(0.1)
        
        if bp then
            for _, tool in pairs(bp:GetChildren()) do
                if tool:IsA("Tool") and string.find(string.lower(tool.Name), string.lower(targetName)) then
                    tool.Parent = char
                    task.wait(0.2)
                    return true
                end
            end
        end
        return false 
    end,
    InitEvents = function(Win)
        local remoteNotif = Framework:GetRemote("Notification")
        local activeCrops = Services.Workspace:FindFirstChild("ActiveCrops")
        
        if remoteNotif and not Framework.DynamicConns.PlanterNotif then
            Framework.DynamicConns.PlanterNotif = remoteNotif.OnClientEvent:Connect(function(msg)
                if not Framework.State.Farming.VegActive then return end
                local txt = string.lower(tostring(msg))
                if string.find(txt, "maksimal") or string.find(txt, "penuh") or string.find(txt, "sudah ada") then 
                    Framework.State.Farming.VegPaused = true 
                end
            end)
            Framework:AddConnection(Framework.DynamicConns.PlanterNotif)
        end
        
        if activeCrops and not Framework.DynamicConns.PlanterReplant then
            Framework.DynamicConns.PlanterReplant = activeCrops.ChildRemoved:Connect(function(child)
                if Framework.State.Farming.VegActive and Framework.State.Farming.VegPaused then
                    local ownerId = child:GetAttribute("OwnerId")
                    if ownerId == Framework.Cache.LocalPlayer.UserId or string.find(child.Name, tostring(Framework.Cache.LocalPlayer.UserId)) then 
                        Framework.State.Farming.VegPaused = false 
                    end
                end
            end)
            Framework:AddConnection(Framework.DynamicConns.PlanterReplant)
        end
    end,
    PlantVegLine = function(Win)
        local char = Framework.Cache.Character
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        if not hrp then return end
        
        local seedName = Framework.Config.Farming.SelectedPlantSayur
        local remotePlant = Framework:GetRemote("PlantCrop")
        local remoteShop = Framework:GetRemote("RequestShop")
        
        if Modules.Farming.GetSeedCount(seedName) <= 0 then
            if Framework.Config.Farming.AutoBuySayur and remoteShop then
                local res = remoteShop:InvokeServer("BUY", seedName, Framework.Config.Farming.AutoBuyAmountSayur)
                if type(res) == "table" and res.Success == false or res == false then
                    Framework.State.Farming.VegActive = false
                    Framework.Config.Farming.AutoBuySayur = false
                    if Win then Win:Notify({Title = "Gagal Beli", Text = "Koin tidak cukup. Auto Tanam Sayur dimatikan!", Duration = 5}) end
                    return
                end
                task.wait(1)
            else 
                return 
            end
        end
        
        if not Modules.Farming.ForceEquipTool(seedName) then return end
        
        local cframe = hrp.CFrame
        local lv = (cframe.LookVector * Vector3.new(1, 0, 1)).Unit
        local rv = cframe.RightVector
        
        for fwd = 1, 3 do
            if not Framework.State.Farming.VegActive or Framework.State.Farming.VegPaused then break end
            local rowPos = cframe.Position + (lv * (Framework.State.Farming.ForwardStep + fwd))
            
            for side = -2, 2 do
                if not Framework.State.Farming.VegActive or Framework.State.Farming.VegPaused then break end
                if Modules.Farming.GetSeedCount(seedName) <= 0 then break end 
                
                local targetPos = rowPos + (rv * side * 1)
                local finalPos = Vector3.new(targetPos.X, hrp.Position.Y - 2.5, targetPos.Z)
                
                if (finalPos - hrp.Position).Magnitude <= Framework.State.Farming.Radius then 
                    if remotePlant then remotePlant:FireServer(finalPos) end
                    task.wait(0.08) 
                end
            end
            task.wait(0.1)
        end
    end,
    PlantFruitRoutine = function(Win)
        local remoteShop = Framework:GetRemote("RequestShop")
        local remoteLahan = Framework:GetRemote("RequestLahan")
        local remotePlantLahan = Framework:GetRemote("PlantLahanCrop")
        
        if not remoteLahan then return end
        local status = remoteLahan:InvokeServer("GET_STATUS")
        local lahanName = status and status.PlayerCurrentLahan
        
        if not lahanName then
            for _, v in pairs(Services.Workspace:GetChildren()) do
                if string.sub(v.Name, 1, 14) == "AreaTanamBesar" then
                    local prompt = v:FindFirstChildWhichIsA("ProximityPrompt", true)
                    if prompt and prompt.Enabled then
                        remoteLahan:InvokeServer("BUY", {["PartName"] = v.Name})
                        task.wait(1)
                        status = remoteLahan:InvokeServer("GET_STATUS")
                        lahanName = status and status.PlayerCurrentLahan
                        break
                    end
                end
            end
        end
        
        if not lahanName then return end
        
        local lahanPart = Services.Workspace:FindFirstChild(lahanName)
        local basePart = lahanPart and (lahanPart:IsA("BasePart") and lahanPart or lahanPart:FindFirstChildWhichIsA("BasePart", true))
        if not basePart then return end
        
        local hasSawit = false
        local hasDurian = false
        local activeCrops = Services.Workspace:FindFirstChild("ActiveCrops")
        
        if activeCrops then
            for _, crop in pairs(activeCrops:GetChildren()) do
                if crop:GetAttribute("OwnerId") == Framework.Cache.LocalPlayer.UserId or string.find(crop.Name, tostring(Framework.Cache.LocalPlayer.UserId)) then
                    local seedType = crop:GetAttribute("SeedType")
                    if seedType == "Bibit Sawit" then 
                        hasSawit = true 
                    elseif seedType == "Bibit Durian" then 
                        hasDurian = true 
                    end
                end
            end
        end
        
        if hasSawit and hasDurian then return end
        
        Framework.State.Farming.VegPaused = true
        task.wait(0.5)
        
        local hrp = Framework.Cache.HumanoidRootPart
        if not hrp then return end
        local originalCFrame = hrp.CFrame
        
        local function doPlantTree(seedName, offsetDir, offsetDist)
            if Modules.Farming.GetSeedCount(seedName) <= 0 then
                if Framework.Config.Farming.AutoBuyBuah and remoteShop then
                    local res = remoteShop:InvokeServer("BUY", seedName, Framework.Config.Farming.AutoBuyAmountBuah)
                    if type(res) == "table" and res.Success == false or res == false then
                        Framework.State.Farming.FruitActive = false
                        Framework.Config.Farming.AutoBuyBuah = false
                        if Win then Win:Notify({Title = "Gagal Beli Buah", Text = "Koin tidak cukup. Auto Tanam Buah dimatikan!", Duration = 5}) end
                        return false
                    end
                    task.wait(1)
                else 
                    return false 
                end
            end
            
            if Modules.Farming.ForceEquipTool(seedName) then
                local targetCFrame = basePart.CFrame * CFrame.new(offsetDir * offsetDist, 3, 0)
                hrp.CFrame = targetCFrame
                task.wait(0.6)
                if remotePlantLahan then remotePlantLahan:FireServer(targetCFrame.Position - Vector3.new(0, 3, 0)) end
                task.wait(0.5)
            end
            return true
        end
        
        if not hasSawit then doPlantTree("Bibit Sawit", -1, 2) end
        if not hasDurian and Framework.State.Farming.FruitActive then doPlantTree("Bibit Durian", 1, 2) end
        
        hrp.CFrame = originalCFrame
        task.wait(0.5)
        Framework.State.Farming.VegPaused = false
    end,
