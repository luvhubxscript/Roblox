                if Win then Win:Notify({Title = "Troll", Text = "Berhasil mengirim request gendong ke " .. target.Name, Duration = 2}) end
            end
        end
    end,
    SummonRain = function(Win)
        local remote = Framework:GetRemote("SummonRain")
        if remote then
            remote:FireServer()
            if Win then Win:Notify({Title = "Exploit", Text = "Memaksa cuaca menjadi hujan...", Duration = 3}) end
        end
    end,
    SendGiftQueue = function(targetString, queueTable, Win)
        local targetName = string.match(targetString, "%(@(.-)%)") or targetString
        local target = Services.Players:FindFirstChild(targetName)
        
        if not target then 
            if Win then Win:Notify({Title = "Gagal", Text = "Player target tidak ditemukan!", Duration = 3}) end
            return 
        end
        
        local remoteGift = Framework:GetRemote("RequestGift")
        local remoteDone = Framework:GetRemote("GiftPurchaseDone")
        
        if not remoteGift or not remoteDone then
            if Win then Win:Notify({Title = "Error", Text = "Sistem gagal menemukan remote Gift.", Duration = 3}) end
            return
        end

        local passConfigs = {
            ["DoublePanen"] = 3534985546, ["FastGrow"] = 3542169435, ["ExtraSlots"] = 3542169045,
            ["DoubleSell"] = 3542168668, ["DoubleXP"] = 3542168280, ["RainLover"] = 3542167872,
            ["AutoHarvest"] = 3542161637, ["Boombox"] = 3542161296, ["VIP"] = 3542160882,
            ["AutoFeedChicken"] = 3556635500, ["AutoFeedCow"] = 3556635493,
            ["AutoCollectEgg"] = 3556635498, ["AutoCollectMilk"] = 3556635499
        }

        task.spawn(function()
            for i, passName in ipairs(queueTable) do
                local giftType = Framework.Config.Misc.GiftType
                local fPrice = giftType == "Custom" and Framework.Config.Misc.CustomPrice or (GiftPrices[passName] or 0)
                local fNote = giftType == "Custom" and Framework.Config.Misc.CustomNote or "-"
                local prodId = passConfigs[passName]

                if prodId then
                    remoteGift:InvokeServer("PROMPT_GIFT", target.UserId, passName)
                    task.wait(0.5)
                    remoteDone:FireServer(prodId, true)
                    if Win then Win:Notify({Title = "Gift Berhasil", Text = "Mengirim " .. passName .. " ke " .. target.Name, Duration = 2}) end
                    Modules.Database.LogGift(target.Name, passName, "Berhasil", giftType, fPrice, fNote)
                else
                    if Win then Win:Notify({Title = "Gift Gagal", Text = passName .. " tidak valid!", Duration = 2}) end
                    Modules.Database.LogGift(target.Name, passName, "Gagal (Invalid ID)", giftType, fPrice, fNote)
                end
                
                if i < #queueTable then task.wait(3) end
            end
            if Win then Win:Notify({Title = "Proses Selesai", Text = "Semua antrean Gift selesai diproses.", Duration = 3}) end
            Framework.State.GiftQueue = {}
        end)
    end
}

