                                    if root then
                                        local prompt = root:FindFirstChildOfClass("ProximityPrompt")
                                        if prompt and prompt.Enabled then
                                            local dist = (Framework.Cache.HumanoidRootPart.Position - root.Position).Magnitude
                                            if dist > 7 then 
                                                Framework.Cache.HumanoidRootPart.CFrame = root.CFrame + Vector3.new(0, 3, 0)
                                                task.wait(0.2) 
                                            end
                                            prompt.HoldDuration = 0
                                            fireproximityprompt(prompt, 1)
                                        end
                                    end
                                end
                            end
                        end
                        for _, item in pairs(Services.Workspace:GetChildren()) do
                            if item:IsA("Model") or item:IsA("BasePart") then
                                local fType = item:GetAttribute("FruitType")
                                local fOwner = item:GetAttribute("OwnerId")
                                if fType and fOwner == Framework.Cache.LocalPlayer.UserId then
                                    local fPrompt = item:FindFirstChildWhichIsA("ProximityPrompt", true)
                                    if fPrompt and fPrompt.Enabled then
                                        local fDist = (Framework.Cache.HumanoidRootPart.Position - fPrompt.Parent.Position).Magnitude
                                        if fDist > 7 then 
                                            Framework.Cache.HumanoidRootPart.CFrame = fPrompt.Parent.CFrame + Vector3.new(0, 3, 0)
                                            task.wait(0.2) 
                                        end
                                        fPrompt.HoldDuration = 0
                                        fireproximityprompt(fPrompt, 1)
                                    end
                                end
                            end
                        end
                    end)
                    task.wait(0.3)
                end
            end)
        else 
            Framework:CancelTask("AutoHarvestTask") 
        end
    end,
    ToggleAutoAnimal = function(state)
        Framework.Config.Farming.AutoAnimal = state
        if state then
            Framework:CancelTask("AutoAnimalTask")
            Framework.ActiveTasks["AutoAnimalTask"] = task.spawn(function()
                while Framework.Config.Farming.AutoAnimal and Framework.Running do
                    pcall(function()
                        if not Framework.Cache.HumanoidRootPart then return end
                        for _, animal in pairs(Services.Workspace:GetDescendants()) do
                            if animal:IsA("Model") and (string.find(animal.Name, "Ayam") or string.find(animal.Name, "Sapi")) then
                                local aOwner = animal:GetAttribute("OwnerId")
                                if aOwner == Framework.Cache.LocalPlayer.UserId then
                                    local aPrompt = animal:FindFirstChildWhichIsA("ProximityPrompt", true)
                                    if aPrompt and aPrompt.Enabled then
                                        local actionTxt = string.lower(aPrompt.ActionText)
                                        if string.find(actionTxt, "makan") or string.find(actionTxt, "panen") or string.find(actionTxt, "ambil") then
                                            local originCF = Framework.Cache.HumanoidRootPart.CFrame
                                            Framework.Cache.HumanoidRootPart.CFrame = aPrompt.Parent.CFrame + Vector3.new(0, 3, 0)
                                            task.wait(0.2)
                                            aPrompt.HoldDuration = 0
                                            fireproximityprompt(aPrompt, 1)
                                            task.wait(0.2)
                                            Framework.Cache.HumanoidRootPart.CFrame = originCF
                                        end
                                    end
                                end
                            end
                        end
                    end)
                    task.wait(2)
                end
            end)
        else 
            Framework:CancelTask("AutoAnimalTask") 
        end
    end,
    ToggleCropESP = function(state, WinGui)
        Framework.Config.Farming.CropESP = state
        if state then
            Framework:CancelTask("CropESPTask")
            Framework.ActiveTasks["CropESPTask"] = task.spawn(function()
                while Framework.Config.Farming.CropESP and Framework.Running do
                    pcall(function()
                        local activeCrops = Services.Workspace:FindFirstChild("ActiveCrops")
                        if activeCrops then
                            local currentTime = Services.Workspace:GetServerTimeNow()
                            for _, crop in pairs(activeCrops:GetChildren()) do
                                local ownerId = crop:GetAttribute("OwnerId")
                                if ownerId == Framework.Cache.LocalPlayer.UserId or string.find(crop.Name, tostring(Framework.Cache.LocalPlayer.UserId)) then
                                    local espName = "ESP_" .. crop.Name
                                    local esp = WinGui:FindFirstChild(espName)
                                    local root = crop:FindFirstChild("Root")
                                    if root then
                                        if not esp then
                                            esp = Instance.new("BillboardGui")
                                            esp.Name = espName
                                            esp.Size = UDim2.new(0, 150, 0, 40)
                                            esp.StudsOffset = Vector3.new(0, 3, 0)
                                            esp.AlwaysOnTop = true
                                            esp.Adornee = root
                                            local txt = Instance.new("TextLabel")
                                            txt.Name = "Text"
                                            txt.Parent = esp
                                            txt.Size = UDim2.new(1, 0, 1, 0)
                                            txt.BackgroundTransparency = 1
                                            txt.Font = Enum.Font.GothamBold
                                            txt.TextScaled = true
                                            txt.TextStrokeTransparency = 0.2
                                            txt.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
                                            esp.Parent = WinGui
                                        end
                                        if esp.Adornee ~= root then 
                                            esp.Adornee = root 
                                        end
                                        local txt = esp:FindFirstChild("Text")
                                        if txt then
                                            local isReady = crop:GetAttribute("IsReady")
                                            local plantedAt = crop:GetAttribute("PlantedAt")
                                            local growthTime = crop:GetAttribute("GrowthTime")
                                            local seedName = crop:GetAttribute("SeedType") or "Tanaman"
                                            if isReady then 
                                                txt.Text = seedName .. "\n[ 100% READY ]"
                                                txt.TextColor3 = Color3.fromRGB(50, 255, 50)
                                            elseif plantedAt and growthTime then
                                                local elapsed = currentTime - plantedAt
                                                local pct = math.floor((elapsed / growthTime) * 100)
                                                if pct >= 100 then pct = 99 end
                                                if pct < 0 then pct = 0 end
                                                txt.Text = seedName .. "\n(" .. pct .. "%)"
                                                txt.TextColor3 = Color3.fromRGB(255, 170, 0)
                                            else 
                                                txt.Text = seedName .. "\n..."
                                                txt.TextColor3 = Color3.fromRGB(200, 200, 200) 
                                            end
                                        end
                                    else 
                                        if esp then esp:Destroy() end 
                                    end
                                end
                            end
                        end
                        for _, child in pairs(WinGui:GetChildren()) do
                            if string.sub(child.Name, 1, 4) == "ESP_" then 
                                if not child.Adornee or not child.Adornee.Parent then 
                                    child:Destroy() 
                                end 
                            end
                        end
                    end)
                    task.wait(0.3)
                end
            end)
        else
            Framework:CancelTask("CropESPTask")
            if WinGui then 
                for _, child in pairs(WinGui:GetChildren()) do 
                    if string.sub(child.Name, 1, 4) == "ESP_" then 
                        child:Destroy() 
                    end 
                end 
            end
        end
    end
}

