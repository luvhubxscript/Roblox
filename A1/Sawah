                        local myPlantCount = 0
                        for _, crop in pairs(activeCrops:GetChildren()) do
                            local ownerId = crop:GetAttribute("OwnerId")
                            if ownerId == Framework.Cache.LocalPlayer.UserId or string.find(crop.Name, tostring(Framework.Cache.LocalPlayer.UserId)) then
                                myPlantCount = myPlantCount + 1
                            end
                        end

                        local currentSeeds = Modules.Farming.GetSeedCount(Framework.Config.Farming.SelectedPlantSayur)
                        if currentSeeds <= 2 and Framework.Config.Farming.AutoBuyAFK and myPlantCount == 0 then
                            local remoteShop = Services.ReplicatedStorage.Remotes.TutorialRemotes:FindFirstChild("RequestShop")
                            if remoteShop then
                                remoteShop:InvokeServer("BUY", Framework.Config.Farming.SelectedPlantSayur, Framework.Config.Farming.AutoBuyAmount)
                                task.wait(1.5) 
                            end
                        end

                        if myPlantCount == 0 then
                            local maxPlant = 15
                            local area = Services.Workspace:FindFirstChild(Framework.Config.Farming.TargetAreaSayur)
                            local remotePlant = Services.ReplicatedStorage.Remotes.TutorialRemotes:FindFirstChild("PlantCrop")

                            if area and remotePlant then
                                local basePart = area:IsA("BasePart") and area or area:FindFirstChildWhichIsA("BasePart", true)
                                if basePart and Framework.Cache.HumanoidRootPart then
                                    local hrp = Framework.Cache.HumanoidRootPart
                                    Framework.Config.Farming.IsPlanting = true

                                    local spacing = 2.5
                                    local maxRow = 5
                                    local baseCF = basePart.CFrame
                                    local startX = -((maxRow - 1) * spacing) / 2
                                    local startZ = -((math.floor((maxPlant - 1) / maxRow)) * spacing) / 2

                                    for i = 1, maxPlant do
                                        if not Framework.Running or not Framework.Config.Farming.AutoFarmAFK then break end
                                        
                                        if Modules.Farming.GetSeedCount(Framework.Config.Farming.SelectedPlantSayur) == 0 then 
                                            if Framework.Config.Farming.AutoBuyAFK then
                                                local remoteShop = Services.ReplicatedStorage.Remotes.TutorialRemotes:FindFirstChild("RequestShop")
                                                if remoteShop then
                                                    remoteShop:InvokeServer("BUY", Framework.Config.Farming.SelectedPlantSayur, Framework.Config.Farming.AutoBuyAmount)
                                                    task.wait(1.5)
                                                end
                                            else
                                                break
                                            end
                                            
                                            if Modules.Farming.GetSeedCount(Framework.Config.Farming.SelectedPlantSayur) == 0 then
                                                Framework.Config.Farming.AutoFarmAFK = false
                                                break
                                            end
                                        end

                                        Modules.Farming.ForceEquipTool(Framework.Config.Farming.SelectedPlantSayur)
                                        task.wait(0.1)

                                        local row = math.floor((i - 1) / maxRow)
                                        local col = (i - 1) % maxRow

                                        local localOffset = CFrame.new(startX + (col * spacing), 0, startZ + (row * spacing))
                                        local plantPos = (baseCF * localOffset).Position
                                        plantPos = Vector3.new(plantPos.X, basePart.Position.Y, plantPos.Z)

                                        local charPos = plantPos + Vector3.new(1.5, 4, 1.5)
                                        hrp.CFrame = CFrame.new(charPos, Vector3.new(plantPos.X, charPos.Y, plantPos.Z))
                                        
                                        task.wait(0.2)
                                        remotePlant:FireServer(plantPos)
                                        task.wait(0.1)
                                    end
                                    Framework.Config.Farming.IsPlanting = false
                                end
                            end
                        end
                    end)
                    task.wait(1)
                end
            end)
        else
            Framework:CancelTask("AutoFarmAFKTask")
        end
    end
}

