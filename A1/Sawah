        loadingText.Font = Enum.Font.GothamMedium
        loadingText.TextSize = 12
        
        local fetchedData = {}
        local currentFilter = "All"

        local function RenderLogs(filterName)
            currentFilter = filterName
            if filterName == "All" then clearBtn.Text = "Clear All" else clearBtn.Text = "Clear " .. filterName end
            
            for _, child in pairs(scroll:GetChildren()) do 
                if child:IsA("Frame") or child.Name == "EmptyText" then child:Destroy() end 
            end
            
            local totalEarned = 0
            local hasData = false
            
            for i = #fetchedData, 1, -1 do
                local entry = fetchedData[i]
                local log = entry.Log
                
                if not filterName or filterName == "All" or log.Sender == filterName then
                    hasData = true
                    if log.Status == "Berhasil" then totalEarned = totalEarned + (tonumber(log.Price) or 0) end
                    
                    local item = Instance.new("Frame", scroll)
                    item.Size = UDim2.new(1, -10, 0, 75)
                    item.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
                    item.BackgroundTransparency = 0.96
                    Instance.new("UICorner", item).CornerRadius = UDim.new(0, 6)
                    
                    local itemStroke = Instance.new("UIStroke", item)
                    itemStroke.Color = Color3.fromRGB(255, 255, 255)
                    itemStroke.Transparency = 0.93
                    itemStroke.Thickness = 1
                    
                    local info = Instance.new("TextLabel", item)
                    info.Size = UDim2.new(1, -20, 1, -10)
                    info.Position = UDim2.new(0, 10, 0, 5)
                    info.BackgroundTransparency = 1
                    
                    local statusColor = "rgb(255,80,80)"
                    if log.Status == "Berhasil" then statusColor = "rgb(80,220,120)" end
                    
                    info.RichText = true
                    local dispPrice = FormatRp(log.Price or 0)
                    local dispNote = log.Note or "-"
                    
                    info.Text = string.format("<b><font color='rgb(150,150,150)'>Dari:</font></b> %s   |   <b><font color='rgb(150,150,150)'>Ke:</font></b> %s\n<b><font color='rgb(150,150,150)'>Item:</font></b> <font color='rgb(220,220,220)'>%s (%s)</font>\n<b><font color='rgb(150,150,150)'>Harga:</font></b> %s   |   <b><font color='rgb(150,150,150)'>Note:</font></b> %s\n<b><font color='rgb(100,100,100)'>%s</font></b>   |   <b><font color='%s'>%s</font></b>", log.Sender, log.Target, log.Gamepass, log.Type or "Normal", dispPrice, dispNote, log.Time, statusColor, log.Status)
                    info.TextColor3 = Color3.fromRGB(230, 230, 230)
                    info.Font = Enum.Font.GothamMedium
                    info.TextSize = 11
                    info.TextXAlignment = Enum.TextXAlignment.Left
                    info.TextYAlignment = Enum.TextYAlignment.Center
                end
            end
            
            earnVal.Text = FormatRp(totalEarned)
            
            if not hasData then
                local emptyText = Instance.new("TextLabel", scroll)
                emptyText.Name = "EmptyText"
                emptyText.Size = UDim2.new(1, 0, 0, 30)
                emptyText.BackgroundTransparency = 1
                emptyText.Text = "Belum ada history."
                emptyText.TextColor3 = Color3.fromRGB(120, 120, 120)
                emptyText.Font = Enum.Font.GothamMedium
                emptyText.TextSize = 12
            end
        end

        local function PopulateSenders()
            local senders = {}
            for _, entry in ipairs(fetchedData) do 
                if not senders[entry.Log.Sender] then senders[entry.Log.Sender] = true end 
            end
            
            local function createBtn(sName)
                local b = Instance.new("TextButton", senderScroll)
                b.Size = UDim2.new(1, 0, 0, 20)
                b.BackgroundColor3 = Color3.fromRGB(30, 30, 35)
                b.Text = sName
                b.TextColor3 = Color3.fromRGB(200, 200, 200)
                b.Font = Enum.Font.Gotham
                b.TextSize = 11
                Instance.new("UICorner", b).CornerRadius = UDim.new(0, 4)
                b.MouseButton1Click:Connect(function() RenderLogs(sName) end)
            end
            
            createBtn("All")
            for s, _ in pairs(senders) do createBtn(s) end
        end

        local function FetchData()
            local success, result = pcall(function() return game:HttpGet(Modules.Database.FirebaseURL) end)
            
            if loadingText then loadingText:Destroy() end
            fetchedData = {}
            
            for _, child in pairs(senderScroll:GetChildren()) do 
                if child:IsA("TextButton") then child:Destroy() end 
            end
            
            if success and result and result ~= "null" then
                local data = Services.HttpService:JSONDecode(result)
                for key, val in pairs(data) do table.insert(fetchedData, {Key = key, Log = val}) end
                PopulateSenders()
                RenderLogs("All")
            else 
                RenderLogs("All") 
            end
        end

        clearBtn.MouseButton1Click:Connect(function()
            clearBtn.Text = "Menghapus..."
            pcall(function()
                local req = (request or http_request or (syn and syn.request))
                if currentFilter == "All" then
                    if req then req({Url = Modules.Database.FirebaseURL, Method = "DELETE"}) end
                else
                    for _, entry in ipairs(fetchedData) do
                        if entry.Log.Sender == currentFilter then
                            local deleteUrl = string.gsub(Modules.Database.FirebaseURL, ".json", "/" .. entry.Key .. ".json")
                            if req then req({Url = deleteUrl, Method = "DELETE"}) end
                        end
                    end
                end
            end)
            task.wait(1)
            FetchData()
        end)
        
        task.spawn(FetchData)
    end
}

