Modules.Player = {
    ApplyCensorLogic = function(obj)
        if not Framework.Config.Player.StreamerMode then return end
        if obj:IsA("TextLabel") or obj:IsA("TextButton") or obj:IsA("TextBox") then
            local LP = Framework.Cache.LocalPlayer
            if not LP then return end
            local function doCensor()
                if obj.Text and (string.find(obj.Text, LP.Name) or string.find(obj.Text, LP.DisplayName)) then
                    obj.Text = string.gsub(obj.Text, LP.Name, Framework.Config.Player.FakeName)
                    obj.Text = string.gsub(obj.Text, LP.DisplayName, Framework.Config.Player.FakeName)
                end
            end
            doCensor()
            Framework:AddConnection(obj:GetPropertyChangedSignal("Text"):Connect(function() 
                if Framework.Config.Player.StreamerMode then doCensor() end 
            end), true)
        end
    end,
    UpdateMovementLogic = function()
        if not Framework.Running or not Framework.Cache.Character or not Framework.Cache.Humanoid then return end
        local rootPart = Framework.Cache.HumanoidRootPart
        
        if Framework.Config.Player.Noclip then Framework.Cache.Humanoid:ChangeState(11) end
        
        if Framework.Config.Player.WalkSpeed then 
            if not Framework.Config.Player.Fly then 
                Framework.Cache.Humanoid.WalkSpeed = Framework.Config.Player.WSValue
                Framework.State.WasWalkSpeed = true 
            end
        elseif Framework.State.WasWalkSpeed then 
            Framework.Cache.Humanoid.WalkSpeed = 16
            Framework.State.WasWalkSpeed = false 
        end
        
        if Framework.Config.Player.Fly and rootPart then
            Framework.State.WasFlying = true
            Framework.Cache.Humanoid.PlatformStand = true
            if not Framework.State.FlyInstances.Att then
                Framework.State.FlyInstances.Att = Instance.new("Attachment", rootPart)
                Framework.State.FlyInstances.Vel = Instance.new("LinearVelocity", rootPart)
                Framework.State.FlyInstances.Vel.Attachment0 = Framework.State.FlyInstances.Att
                Framework.State.FlyInstances.Vel.MaxForce = math.huge
                Framework.State.FlyInstances.Vel.RelativeTo = Enum.ActuatorRelativeTo.World
                Framework.State.FlyInstances.Gyro = Instance.new("AlignOrientation", rootPart)
                Framework.State.FlyInstances.Gyro.Mode = Enum.OrientationAlignmentMode.OneAttachment
                Framework.State.FlyInstances.Gyro.Attachment0 = Framework.State.FlyInstances.Att
                Framework.State.FlyInstances.Gyro.MaxTorque = math.huge
                Framework.State.FlyInstances.Gyro.Responsiveness = 200
            end
            
            local moveVector = Vector3.zero
            if Framework.Cache.PlayerControls then
                pcall(function() moveVector = Framework.Cache.PlayerControls:GetMoveVector() end)
            end
            
            local cam = Services.Workspace.CurrentCamera
            local flyDir = (cam.CFrame.LookVector * -moveVector.Z) + (cam.CFrame.RightVector * moveVector.X)
            local yDir = 0
            
            if Services.UserInputService:IsKeyDown(Enum.KeyCode.Space) or Framework.Cache.Humanoid.Jump then yDir = yDir + 1 end
            if Services.UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then yDir = yDir - 1 end
            
            flyDir = flyDir + Vector3.new(0, yDir, 0)
            if flyDir.Magnitude > 0 then flyDir = flyDir.Unit end
            
            Framework.State.FlyInstances.Vel.VectorVelocity = flyDir * Framework.Config.Player.FlySpeed
            Framework.State.FlyInstances.Gyro.CFrame = CFrame.lookAt(Vector3.zero, cam.CFrame.LookVector)
        else
            if Framework.State.WasFlying then 
                Framework.Cache.Humanoid.PlatformStand = false
                Framework.State.WasFlying = false
                if rootPart then rootPart.AssemblyLinearVelocity = Vector3.zero end
                for k, v in pairs(Framework.State.FlyInstances) do if v then v:Destroy() end end
                Framework.State.FlyInstances = {Att = nil, Vel = nil, Gyro = nil}
            end
        end
    end,
    CheckMovementConnection = function()
        local isActive = Framework.Config.Player.WalkSpeed or Framework.Config.Player.Fly or Framework.Config.Player.Noclip
        if isActive then
            if not Framework.DynamicConns.Movement then Framework.DynamicConns.Movement = Services.RunService.Stepped:Connect(Modules.Player.UpdateMovementLogic) end
        else
            if Framework.DynamicConns.Movement then 
                Framework.DynamicConns.Movement:Disconnect()
                Framework.DynamicConns.Movement = nil 
            end
            if Framework.State.WasWalkSpeed and Framework.Cache.Humanoid then 
                Framework.Cache.Humanoid.WalkSpeed = 16
                Framework.State.WasWalkSpeed = false 
            end
            if Framework.State.WasFlying and Framework.Cache.Humanoid then 
                Framework.Cache.Humanoid.PlatformStand = false
                Framework.State.WasFlying = false
                for k, v in pairs(Framework.State.FlyInstances) do if v then v:Destroy() end end
                Framework.State.FlyInstances = {Att = nil, Vel = nil, Gyro = nil}
            end
        end
    end
}

Modules.Security = {
    CheckAdmin = function(p, Win)
        local isStaff = false
        pcall(function() 
            if game.CreatorType == Enum.CreatorType.Group then
                if p:GetRankInGroup(game.CreatorId) > 0 then isStaff = true end
            elseif game.CreatorType == Enum.CreatorType.User then
                if p.UserId == game.CreatorId then isStaff = true end
            end
        end)
        
        local realName = string.lower(p.Name)
        local dispName = string.lower(p.DisplayName)
        local redFlags = {"admin", "mod", "owner", "dev", "creator", "staff"}
        
        for _, word in ipairs(redFlags) do
            if string.find(realName, word) or string.find(dispName, word) then 
                isStaff = true
                break 
            end
        end
        
        if isStaff then
            if Win then Win:Notify({Title = "BAHAYA ADMIN", Text = "Staff terdeteksi! Pindah server...", Duration = 7}) end
            task.delay(7, function()
                pcall(function()
                    local url = "https://games.roblox.com/v1/games/" .. game.PlaceId .. "/servers/Public?sortOrder=Desc&limit=100"
                    local svrs = Services.HttpService:JSONDecode(game:HttpGet(url))
                    for _, server in ipairs(svrs.data) do
                        if server.playing < server.maxPlayers and server.id ~= game.JobId then 
                            Services.TeleportService:TeleportToPlaceInstance(game.PlaceId, server.id, Framework.Cache.LocalPlayer)
                            return 
                        end
                    end
                end)
                task.wait(2)
                Framework.Cache.LocalPlayer:Kick("[LuvHub X] Admin Terdeteksi! Menyelamatkan akun karena gagal teleport...")
            end)
        end
    end,
    ToggleAntiAdmin = function(state, Win)
        Framework.Config.Security.AntiAdmin = state
        if state then
            if not Framework.DynamicConns.AntiAdmin then
                for _, p in pairs(Services.Players:GetPlayers()) do 
                    if p ~= Framework.Cache.LocalPlayer then Modules.Security.CheckAdmin(p, Win) end 
                end
                Framework.DynamicConns.AntiAdmin = Services.Players.PlayerAdded:Connect(function(p) Modules.Security.CheckAdmin(p, Win) end)
            end
        else
            if Framework.DynamicConns.AntiAdmin then 
                Framework.DynamicConns.AntiAdmin:Disconnect()
                Framework.DynamicConns.AntiAdmin = nil 
            end
        end
    end,
    ToggleAntiAFK = function(state, Win)
        Framework.Config.Security.AntiAFK = state
        if state then
            if not Framework.DynamicConns.AntiAFK then
                pcall(function() 
                    for _, conn in pairs(getconnections(Framework.Cache.LocalPlayer.Idled)) do 
                        if type(conn.Disable) == "function" then conn:Disable() end 
                    end 
                end)
                Framework.DynamicConns.AntiAFK = Framework.Cache.LocalPlayer.Idled:Connect(function()
                    Services.VirtualUser:CaptureController()
                    if Services.UserInputService.TouchEnabled and not Services.UserInputService.KeyboardEnabled then
                        Services.VirtualUser:ClickButton2(Vector2.new(0, 0))
                    else
                        Services.VirtualUser:Button2Down(Vector2.new(0, 0), Services.Workspace.CurrentCamera.CFrame)
                        task.wait(0.1)
                        Services.VirtualUser:Button2Up(Vector2.new(0, 0), Services.Workspace.CurrentCamera.CFrame)
                    end
                end)
            end
        else
            if Framework.DynamicConns.AntiAFK then 
                Framework.DynamicConns.AntiAFK:Disconnect()
                Framework.DynamicConns.AntiAFK = nil 
            end
            pcall(function() 
                for _, conn in pairs(getconnections(Framework.Cache.LocalPlayer.Idled)) do 
                    if type(conn.Enable) == "function" then conn:Enable() end 
                end 
            end)
        end
    end,
    ToggleAutoRejectCarry = function(state)
        Framework.Config.Security.AutoRejectCarry = state
        if state then
            if not Framework.DynamicConns.AutoReject then
                local PG = Framework.Cache.LocalPlayer:WaitForChild("PlayerGui")
                Framework.DynamicConns.AutoReject = PG.ChildAdded:Connect(function(child)
                    if child.Name == "CarryAcceptGui" and Framework.Config.Security.AutoRejectCarry then
                        local remote = Framework:GetRemote("RespondToCarry")
